<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>Tech Academy - Home</title>

    <style>
        /* ===== CUSTOM COLORS ===== */
        body {
            margin: 0;
            font-family: Arial, sans-serif;
            background-color: #f0f4f8;
        }

        header {
            background-color: #0b3d91;
            color: white;
            padding: 15px 30px;
        }

        /* ===== FLEXBOX NAV ===== */
        .nav-container {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        nav ul {
            display: flex;
            list-style: none;
            gap: 20px;
            padding: 0;
        }

        nav a {
            color: white;
            text-decoration: none;
            font-weight: bold;
        }

        /* ===== HERO SECTION WITH BACKGROUND IMAGE ===== */
        .hero {
            background-image: url("images/banner.jpg");
            background-size: cover;
            background-position: center;
            height: 320px;

            display: flex;
            justify-content: center;
            align-items: center;

            color: white;
            font-size: 40px;
            font-weight: bold;

            text-shadow: 2px 2px 10px black;
        }

        /* ===== SECTION STYLING ===== */
        main {
            padding: 20px;
        }

        .welcome {
            background-color: white;
            padding: 20px;
            border-radius: 12px;
            border: 2px solid #0b3d91;
            box-shadow: 0 4px 10px rgba(0, 0, 0, 0.2);
            margin-bottom: 20px;
        }

        /* ===== GRID LAYOUT ===== */
        .courses {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 20px;
        }

        .card {
            background: white;
            border-radius: 15px;
            border: 1px solid #ddd;
            box-shadow: 0 5px 12px rgba(0, 0, 0, 0.2);
            overflow: hidden;
        }

        .card img {
            width: 100%;
            height: 160px;
            object-fit: cover;
        }

        .card-content {
            padding: 15px;
        }

        .card h3 {
            margin-top: 0;
            color: #0b3d91;
        }

        /* ===== FOOTER ===== */
        footer {
            background-color: #0b3d91;
            color: white;
            text-align: center;
            padding: 15px;
            margin-top: 20px;
        }
    </style>
</head>

<body>

    <!-- HEADER -->
    <header>
        <div class="nav-container">
            <h2>Tech Academy</h2>

            <nav>
                <ul>
                    <li><a href="index.html">Home</a></li>
                    <li><a href="about.html">About</a></li>
                    <li><a href="courses.html">Courses</a></li>
                    <li><a href="contact.html">Contact</a></li>
                </ul>
            </nav>
        </div>
    </header>

    <!-- HERO SECTION -->
    <div class="hero">
        Learn Tech Skills the Smart Way
    </div>

    <!-- MAIN CONTENT -->
    <main>

        <!-- WELCOME SECTION -->
        <section class="welcome">
            <h2>Welcome Message</h2>
            <p>
                Welcome to Tech Academy, where we train students in Web Development,
                Graphic Design, Data Science, Cyber Security, and Mobile App Development.
            </p>
        </section>

        <!-- FEATURED COURSES (GRID) -->
        <section>
            <h2>Featured Courses</h2>

            <div class="courses">

                <div class="card">
                    <img src="images/webdev.jpg" alt="Web Development">
                    <div class="card-content">
                        <h3>Web Development</h3>
                        <p>Learn HTML, CSS, JavaScript and build websites.</p>
                    </div>
                </div>

                <div class="card">
                    <img src="images/design.jpg" alt="Graphic Design">
                    <div class="card-content">
                        <h3>Graphic Design</h3>
                        <p>Create logos, posters and digital artwork.</p>
                    </div>
                </div>

                <div class="card">
                    <img src="images/data.jpg" alt="Data Science">
                    <div class="card-content">
                        <h3>Data Science</h3>
                        <p>Analyze data and create insights using tools.</p>
                    </div>
                </div>

            </div>
        </section>

    </main>

    <!-- FOOTER -->
    <footer>
        <p>© 2026 Tech Academy. All Rights Reserved.</p>
    </footer>

</body>

</html>
